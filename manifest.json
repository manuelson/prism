{
  "manifest_version": 3,
  "name": "PRism",
  "version": "1.0.0",
  "description": "View your open GitHub Pull Requests and review requests",
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://api.github.com/*", "https://github.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
